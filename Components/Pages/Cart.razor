@page "/cart"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Bookstore.Data
@using Bookstore.Models
@using Bookstore.Services
@inject IDbContextFactory<BookstoreDb> DbFactory
@inject CartService CartService
@inject NavigationManager Navigation

<PageTitle>Cart - Bookstore</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Shopping Cart</h1>
        <div class="d-flex align-items-center gap-3">
            <span class="fw-bold text-success fs-5">Wallet: @CartService.WalletBalance.ToString("C")</span>
            <button class="btn btn-outline-primary" @onclick="ShowAddFundsDialog">Add Funds</button>
        </div>
    </div>

    @if (CartService.Items.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <p class="fs-4 mb-3">Your cart is empty</p>
            <a href="/" class="btn btn-primary">Browse Books</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <div class="row fw-bold">
                    <div class="col-6">Book</div>
                    <div class="col-2 text-center">Price</div>
                    <div class="col-2 text-center">Quantity</div>
                    <div class="col-2 text-end">Subtotal</div>
                </div>
            </div>
            <div class="card-body p-0">
                @foreach (var item in CartService.Items)
                {
                    var subtotal = item.Book.Price * item.Quantity;
                    <div class="row p-3 border-bottom align-items-center">
                        <div class="col-6">
                            <span class="fw-semibold">@item.Book.Title</span>
                            <br><small class="text-muted">@item.Book.Author</small>
                        </div>
                        <div class="col-2 text-center">@item.Book.Price.ToString("C")</div>
                        <div class="col-2 text-center">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary" @onclick="() => DecrementQuantity(item)" disabled="@(item.Quantity <= 1)">-</button>
                                <span class="btn btn-light border">@item.Quantity</span>
                                <button class="btn btn-outline-secondary" @onclick="() => IncrementQuantity(item)">+</button>
                            </div>
                        </div>
                        <div class="col-2 text-end">
                            <span class="fw-semibold">@subtotal.ToString("C")</span>
                            <button class="btn btn-link text-danger btn-sm ms-2" @onclick="() => RemoveItem(item)">Remove</button>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer bg-light">
                <div class="row">
                    <div class="col-10 text-end fw-bold fs-5">Cart Total:</div>
                    <div class="col-2 text-end fw-bold fs-5 text-primary">@CartService.GetCartTotal().ToString("C")</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        <div class="d-flex justify-content-end gap-3">
            <button class="btn btn-outline-secondary" @onclick="ClearCart">Clear Cart</button>
            <button class="btn btn-success btn-lg" @onclick="Checkout" disabled="@(CartService.WalletBalance < CartService.GetCartTotal())">
                Checkout (@CartService.WalletBalance.ToString("C") available)
            </button>
        </div>

        @if (CartService.WalletBalance < CartService.GetCartTotal())
        {
            <p class="text-danger text-end mt-2">Insufficient funds. Please add more to your wallet.</p>
        }
    }
</div>

@if (showAddFundsDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Funds</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddFundsDialog"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Amount to add:</label>
                    <input type="number" class="form-control" @bind="fundsAmount" min="0.01" step="0.01" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddFundsDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="AddFunds">Add</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showAddFundsDialog = false;
    private decimal fundsAmount;
    private string? successMessage;

    private void IncrementQuantity(Bookstore.Services.CartItem item)
    {
        CartService.AddToCart(item.Book, 1);
    }

    private void DecrementQuantity(Bookstore.Services.CartItem item)
    {
        if (item.Quantity > 1)
        {
            CartService.UpdateQuantity(item.Book.Id, item.Quantity - 1);
        }
    }

    private void RemoveItem(Bookstore.Services.CartItem item)
    {
        CartService.RemoveFromCart(item.Book.Id);
    }

    private void ClearCart()
    {
        CartService.ClearCart();
    }

    private void ShowAddFundsDialog()
    {
        fundsAmount = 10;
        showAddFundsDialog = true;
    }

    private void CloseAddFundsDialog()
    {
        showAddFundsDialog = false;
    }

    private void AddFunds()
    {
        if (fundsAmount > 0)
        {
            CartService.AddFunds(fundsAmount);
            showAddFundsDialog = false;
        }
    }

    private async Task Checkout()
    {
        if (CartService.WalletBalance < CartService.GetCartTotal() || CartService.Items.Count == 0)
            return;

        using var context = await DbFactory.CreateDbContextAsync();

        var order = new Order
        {
            OrderDate = DateTime.Now,
            OrderItems = CartService.Items.Select(i => new OrderItem
            {
                BookId = i.Book.Id,
                Quantity = i.Quantity,
                TotalPrice = i.Book.Price * i.Quantity
            }).ToList()
        };

        context.Orders.Add(order);
        await context.SaveChangesAsync();

        CartService.Checkout();
        successMessage = $"Order #{order.Id} placed successfully! Total: {order.GetTotal().ToString("C")}";
    }
}
